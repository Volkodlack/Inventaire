<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="InventPro">
<meta name="theme-color" content="#07090f">
<link rel="manifest" href="manifest.json">
<link rel="stylesheet" href="style.css">
<title>InventPro — Thierry Carles</title>
</head>
<body>

<header>
  <div class="logo-wrap">
    <img src="logo2.png" alt="Thierry Carles" class="logo-img">
  </div>
  <div class="hright">
    <div class="sdot spin" id="sdot" title="Connexion..."></div>
    <div class="hcount" id="hcount">—</div>
  </div>
</header>

<div class="tabs">
  <div class="tab on"  onclick="goTab('bl',this)">📋 BL</div>
  <div class="tab"     onclick="goTab('sortie',this)">📤 Sortie</div>
  <div class="tab"     onclick="goTab('stock',this)">🗃️ Stock</div>
  <div class="tab"     onclick="goTab('inventaire',this)">📦 Inventaire</div>
  <div class="tab"     onclick="goTab('export',this)">📊 Export</div>
</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- PAGE BL                                                 -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="page on" id="page-bl">
  <div class="bl-steps">
    <div class="bl-step on" id="blStep1">1</div>
    <div class="bl-step-line" id="blLine1"></div>
    <div class="bl-step" id="blStep2">2</div>
  </div>
  <div class="bl-step-labels">
    <span>Scan</span><span>Validation</span>
  </div>

  <!-- PHASE 1 : SCAN -->
  <div id="blPhase1">
    <div class="cam-wrap">
      <video id="blVid" playsinline autoplay muted></video>
      <div class="overlay" id="blScanOverlay" style="display:none">
        <div class="frame"><div class="sline"></div>
          <div class="c tl"></div><div class="c tr"></div>
          <div class="c bl"></div><div class="c br"></div>
        </div>
      </div>
      <div class="cam-off" id="blCamOff"><div class="icon">📷</div><p>Caméra inactive</p></div>
    </div>
    <div class="status" id="blStatus">Appuyez sur Démarrer</div>
    <button class="btn bp" id="blBtnStart" onclick="startBLCam()">📷 Démarrer le scanner</button>
    <button class="btn bs" id="blBtnStop" onclick="stopBLCam()" style="display:none">⏹ Arrêter</button>
    <div class="manual-section">
      <div class="sec-title">Saisie manuelle</div>
      <div class="manual-wrap">
        <input class="manual-input" id="blManInput" placeholder="Code-barres..." type="tel"/>
        <button class="btn bp manualbtn" onclick="blManualScan()">✔</button>
      </div>
    </div>
    <div class="sec-title" style="margin:16px 0 8px">Articles scannés</div>
    <div id="blScanList" class="ilist"></div>
    <div id="blScanEmptyMsg" class="empty" style="padding:24px 20px">
      <div class="eico">📦</div>
      <div class="etit">Aucun article</div>
      <div class="esub">Scannez les articles du bon de livraison</div>
    </div>
    <button class="btn bg" id="btnBLRecap" onclick="goToBLRecap()" style="display:none;margin-top:8px">📋 Voir le récapitulatif →</button>
    <button class="btn br2" onclick="cancelBL()" style="margin-top:8px">🗑 Annuler le BL</button>
  </div>

  <!-- PHASE 2 : RECAP -->
  <div id="blPhase2" style="display:none">
    <div class="bl-summary-header">
      <div class="bl-summary-icon">📦</div>
      <div class="bl-summary-title">Récapitulatif livraison</div>
    </div>
    <div id="blRecapStats" class="bl-recap-stats" style="margin-bottom:12px"></div>
    <div id="blRecapList" class="ilist" style="margin-bottom:12px"></div>
    <button class="btn bg" onclick="addBLToInventory()">✅ Valider et intégrer au stock</button>
    <button class="btn bs" onclick="goBackToScan()" style="margin-top:8px">↩ Modifier</button>
    <button class="btn br2" onclick="cancelBL()" style="margin-top:8px">🗑 Annuler et vider le BL</button>
  </div>
</div>
<!-- ═══════════════════════════════════════════════════════ -->
<!-- PAGE STOCK                                              -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="page" id="page-stock">

  <!-- Barre de recherche -->
  <div class="stock-topbar">
    <div class="stock-search-wrap">
      <span class="stock-search-ico">🔍</span>
      <input class="stock-search-inp" id="stockSearch" placeholder="Nom, code-barres…" oninput="renderStock()" autocomplete="off" type="search"/>
      <button class="stock-search-clear" id="stockSearchClear" onclick="clearStockSearch()" style="display:none">✕</button>
    </div>
  </div>

  <!-- Barre de tri -->
  <div class="stock-sort-bar">
    <span class="stock-sort-lbl">Trier :</span>
    <button class="sort-btn on" id="sortBtn-name"   onclick="setStockSort('name')">Nom <span class="sort-arrow">▲</span></button>
    <button class="sort-btn"   id="sortBtn-group"  onclick="setStockSort('group')">Catégorie <span class="sort-arrow"></span></button>
    <button class="sort-btn"   id="sortBtn-qty"    onclick="setStockSort('qty')">Qté <span class="sort-arrow"></span></button>
    <button class="sort-btn"   id="sortBtn-price"  onclick="setStockSort('price')">Prix <span class="sort-arrow"></span></button>
  </div>

  <div id="stockCount" class="stock-count"></div>
  <div id="stockList"  class="ilist"></div>
  <div id="stockEmpty" class="empty" style="display:none;padding:40px 20px">
    <div class="eico">🔍</div>
    <div class="etit">Aucun résultat</div>
    <div class="esub">Essayez un autre terme de recherche</div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- PAGE SORTIE DE STOCK                                    -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="page" id="page-sortie">
  <div class="sortie-header-card">
    <div class="sortie-header-icon">📤</div>
    <div class="sortie-header-txt">
      <strong>Sortie de stock</strong>
      <span>Scannez un article pour le retirer du stock</span>
    </div>
  </div>

  <div class="cam-wrap">
    <video id="sortieVid" playsinline autoplay muted></video>
    <div class="overlay" id="sortieScanOverlay" style="display:none">
      <div class="frame"><div class="sline"></div>
        <div class="c tl"></div><div class="c tr"></div>
        <div class="c bl"></div><div class="c br"></div>
      </div>
    </div>
    <div class="cam-off" id="sortieCamOff"><div class="icon">📷</div><p>Caméra inactive</p></div>
  </div>
  <div class="status" id="sortieStatus">Appuyez sur Démarrer</div>

  <div class="lscan" id="sortieLscan">
    <div class="ls-lbl">Dernier retrait</div>
    <div class="ls-row">
      <div class="ls-code" id="sortieLscode"></div>
      <span class="ls-badge" id="sortieLsbadge"></span>
    </div>
    <div class="ls-name" id="sortieLsname"></div>
    <div class="ls-qty" id="sortieLsqty"></div>
  </div>

  <button class="btn bp" id="sortieBtnStart" onclick="startSortieCam()">📷 Démarrer le scanner</button>
  <button class="btn bs" id="sortieBtnStop" onclick="stopSortieCam()" style="display:none">⏹ Arrêter</button>

  <div class="manual-section">
    <div class="sec-title">Saisie manuelle</div>
    <div class="manual-wrap">
      <input class="manual-input" id="sortieManInput" placeholder="Code-barres..." type="tel"/>
      <button class="btn bp manualbtn" onclick="sortieManualScan()">✔</button>
    </div>
  </div>

  <!-- Historique des sorties de la session -->
  <div style="margin-top:18px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <div class="sec-title" style="margin:0">Sorties de cette session</div>
      <button class="btn bs" style="width:auto;padding:6px 12px;font-size:11px;margin:0" onclick="clearSortieHistory()">Effacer</button>
    </div>
    <div id="sortieHistory" class="ilist">
      <div class="empty" style="padding:24px 0">
        <div class="eico">📤</div>
        <div class="etit">Aucune sortie</div>
        <div class="esub">Les retraits apparaîtront ici</div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- PAGE INVENTAIRE (vérification physique)                 -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="page" id="page-inventaire">

  <!-- Mode IDLE : pas d'inventaire en cours -->
  <div id="invIdle">
    <div class="inv-hero">
      <div class="inv-hero-icon">📦</div>
      <div class="inv-hero-title">Inventaire physique</div>
      <div class="inv-hero-sub">Scannez tous vos articles pour vérifier les quantités en stock. Un rapport comparatif sera généré à la fin.</div>
    </div>
    <button class="btn bg" onclick="startInventaire()">▶ Démarrer l'inventaire</button>
  </div>

  <!-- Mode ACTIF : inventaire en cours -->
  <div id="invActive" style="display:none">
    <div class="inv-progress-band">
      <div class="inv-progress-bar"><div class="inv-progress-fill" id="invProgressFill" style="width:0%"></div></div>
      <div class="inv-progress-txt" id="invProgressTxt">0 article(s) scanné(s)</div>
    </div>

    <div class="cam-wrap">
      <video id="invVid" playsinline autoplay muted></video>
      <div class="overlay" id="invScanOverlay" style="display:none">
        <div class="frame"><div class="sline"></div>
          <div class="c tl"></div><div class="c tr"></div>
          <div class="c bl"></div><div class="c br"></div>
        </div>
      </div>
      <div class="cam-off" id="invCamOff"><div class="icon">📷</div><p>Caméra inactive</p></div>
    </div>
    <div class="status" id="invStatus">Appuyez sur Démarrer</div>

    <div class="lscan" id="invLscan">
      <div class="ls-lbl">Dernier scan inventaire</div>
      <div class="ls-row">
        <div class="ls-code" id="invLscode"></div>
        <span class="ls-badge" id="invLsbadge"></span>
      </div>
      <div class="ls-name" id="invLsname"></div>
      <div class="ls-qty" id="invLsqty"></div>
    </div>

    <button class="btn bp" id="invBtnStart" onclick="startInvCam()">📷 Démarrer le scanner</button>
    <button class="btn bs" id="invBtnStop" onclick="stopInvCam()" style="display:none">⏹ Arrêter</button>

    <div class="manual-section">
      <div class="sec-title">Saisie manuelle</div>
      <div class="manual-wrap">
        <input class="manual-input" id="invManInput" placeholder="Code-barres..." type="tel"/>
        <button class="btn bp manualbtn" onclick="invManualScan()">✔</button>
      </div>
    </div>

    <!-- Articles scannés pendant l'inventaire -->
    <div style="margin-top:18px">
      <div class="sec-title">Articles scannés</div>
      <div id="invScannedList" class="ilist"></div>
    </div>

    <button class="btn bg" onclick="finishInventaire()" style="margin-top:16px">✅ Terminer et générer le rapport</button>
    <button class="btn br2" onclick="cancelInventaire()" style="margin-top:8px">🗑 Annuler l'inventaire</button>
  </div>

  <!-- Mode RAPPORT -->
  <div id="invReport" style="display:none">
    <div class="inv-report-header">
      <div>📋 Rapport d'inventaire</div>
      <div id="invReportDate" style="font-size:11px;color:var(--dim)"></div>
    </div>

    <!-- Résumé -->
    <div class="inv-summary-grid" id="invSummaryGrid"></div>

    <!-- Liste des écarts -->
    <div class="sec-title" style="margin:16px 0 8px">Détail des écarts</div>
    <div id="invReportList" class="ilist"></div>

    <!-- Total financier -->
    <div class="bl-total-wrap" id="invReportTotal" style="margin-top:16px"></div>

    <button class="btn bg" onclick="applyInventaire()" style="margin-top:16px">✅ Appliquer les corrections au stock</button>
    <button class="btn bs" onclick="resetInventaire()" style="margin-top:8px">↩ Nouvel inventaire</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- PAGE EXPORT                                             -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="page" id="page-export">
  <div class="sec-title">Aperçu de l'inventaire</div>
  <div class="tbl-wrap">
    <table>
      <thead>
        <tr><th>CODE</th><th>NOM</th><th>GROUPE</th><th>QTÉ</th><th>PRIX €</th><th>TOTAL €</th></tr>
      </thead>
      <tbody id="ptbody"></tbody>
    </table>
  </div>
  <div class="sec-title">Exporter</div>
  <input class="einp" id="emailInp" type="email" placeholder="votre@email.com"/>
  <button class="btn bg" onclick="exportMail()">📧 Envoyer par mail</button>
  <button class="btn bp" onclick="downloadXLSX()">⬇️ Télécharger Excel (.xlsx)</button>
  <button class="btn bs" onclick="downloadCSV()">⬇️ Télécharger CSV</button>
  <button class="btn br2 danger-btn" onclick="clearAll()">🗑 Effacer l'inventaire</button>
</div>

<!-- ═══════════════════════ MODALS ═══════════════════════════ -->

<!-- MODAL AJOUT ARTICLE BL -->
<!-- MODAL EDIT ARTICLE (STOCK) -->
<div class="mover" id="mStockEdit">
  <div class="mbox">
    <div class="mtit">✏️ Modifier l'article</div>
    <div style="font-family:var(--mono);font-size:12px;color:var(--cyan);margin-bottom:14px" id="stockEditCodeDisplay"></div>
    <input type="hidden" id="stockEditCode"/>
    <label class="flbl">Nom *</label>
    <input class="finp" id="stockEditName" autocomplete="off"/>
    <label class="flbl">Catégorie</label>
    <select class="finp" id="stockEditGroup"></select>
    <input class="finp" id="stockEditGroupCustom" placeholder="Nom du nouveau groupe" style="display:none;margin-top:6px"/>
    <label class="flbl">Prix unitaire HT (€)</label>
    <input class="finp" id="stockEditPrice" type="number" step="0.01" min="0"/>
    <label class="flbl">Quantité</label>
    <input class="finp" id="stockEditQty" type="number" min="0" step="1"/>
    <div class="mact" style="justify-content:space-between">
      <button class="btn br2" onclick="deleteStockItem()">🗑 Supprimer</button>
      <div style="display:flex;gap:8px">
        <button class="btn bs" onclick="closeM('mStockEdit')">Annuler</button>
        <button class="btn bp" onclick="saveStockEdit()">💾 Enregistrer</button>
      </div>
    </div>
  </div>
</div>

<!-- TOAST DOUCHETTE -->
<div id="douchetteToast" class="douchette-toast" style="display:none">
  <span class="douchette-ico">🔫</span>
  <span id="douchetteToastCode"></span>
</div>

<!-- MODAL NOUVEL ARTICLE BL -->
<div class="mover" id="mBLNewItem">
  <div class="mbox">
    <div class="mtit">🆕 Nouvel article</div>
    <div style="font-size:12px;color:var(--dim);margin-bottom:12px">Code : <code id="blNewCode" style="font-family:var(--mono);color:var(--cyan)"></code></div>
    <label class="flbl">Nom du produit *</label>
    <input class="finp" id="blNewName" placeholder="Ex: Robinet thermostatique" autocomplete="off"/>
    <label class="flbl">Prix unitaire HT (€)</label>
    <input class="finp" id="blNewPrice" type="number" step="0.01" min="0" placeholder="0.00"/>
    <label class="flbl">Catégorie</label>
    <select class="finp" id="blNewGroup"></select>
    <input class="finp" id="blNewGroupCustom" placeholder="Nom du nouveau groupe" style="display:none;margin-top:6px"/>
    <div class="mact">
      <button class="btn bs" onclick="closeM('mBLNewItem')">Annuler</button>
      <button class="btn bp" onclick="saveBLNewItem()">✅ Ajouter</button>
    </div>
  </div>
</div>
</body>